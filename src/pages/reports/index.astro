---
import Base from "../../layouts/Base.astro";
import { reports } from "../../data/reports";
import ReportCard from "../../components/ReportCard.astro";

const formspreeUrl = import.meta.env.PUBLIC_FORMSPREE_URL || "";

const siteUrl = "https://roofingaudit.co";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Roofing Website Audit Reports",
    description: "Real audit reports from Roofing businesses. See the exact issues costing contractors money online.",
    url: `${siteUrl}/reports/`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Reports", item: `${siteUrl}/reports/` },
    ],
  },
];
---

<Base
  title="Audit Reports — Roofing Audit"
  description="Real audit reports from Roofing businesses. See the exact issues costing contractors money online."
  jsonLd={jsonLd}
>
  <section class="pt-28 pb-20 sm:pt-32 sm:pb-28">
    <div class="px-6 md:px-12 lg:px-16">
      <!-- Header (full width) -->
      <div class="hero-reveal mb-12">
        <p class="font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
          Audit Reports
        </p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1]">
          Real reports.<br /><span class="text-accent">Real problems found.</span>
        </h1>
        <p class="hero-reveal mt-4 text-ink-secondary text-lg leading-relaxed max-w-2xl" style="--delay:80ms">
          Every report below is a real Roofing business. Click to see the full diagnostic with issues, dollar impact, and recommended fixes.
        </p>
      </div>

      <div class="flex gap-6 xl:gap-8">
        <!-- Left: reports grid -->
        <div class="min-w-0 flex-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {reports.map((report, i) => (
              <div data-reveal style={`--delay: ${(i + 1) * 80}ms`}>
                <ReportCard report={report} />
              </div>
            ))}
          </div>
        </div>

        <!-- Right: sticky form (desktop only) -->
        <aside class="hidden lg:block w-[300px] xl:w-[320px] flex-none">
          <div class="sticky top-24" data-reveal style="--delay:300ms">
            <div class="rounded-xl border border-rule bg-surface-alt/60 p-6">
              <p class="text-lg font-bold tracking-tight mb-1">
                Free audit
              </p>
              <p class="text-xs text-ink-muted mb-5">
                Full report in 48 hours. No strings.
              </p>

              <form
                id="reports-form"
                class="flex flex-col gap-3"
                action={formspreeUrl}
                method="POST"
                aria-label="Request a free Roofing website audit"
              >
                <input type="hidden" name="_subject" value="Reports Page Audit Request" />
                <input type="text" name="_gotcha" style="display:none" />
                <input
                  type="text"
                  name="business_name"
                  placeholder="Business name"
                  required
                  autocomplete="organization"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <input
                  type="text"
                  name="website"
                  placeholder="yoursite.com"
                  required
                  autocomplete="url"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <input
                  type="email"
                  name="email"
                  placeholder="Email for report"
                  required
                  autocomplete="email"
                  class="w-full px-4 py-3 rounded-lg bg-surface border border-rule text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300"
                />
                <button
                  type="submit"
                  id="reports-submit"
                  class="w-full px-5 py-3.5 rounded-lg bg-accent text-white text-sm font-semibold hover:bg-accent-hover transition-colors duration-300 cursor-pointer"
                >
                  Run My Free Audit
                </button>
              </form>

              <div id="reports-success" class="hidden text-center py-6">
                <div class="w-10 h-10 rounded-full bg-success/15 flex items-center justify-center mx-auto mb-3">
                  <svg class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-sm font-semibold mb-1">We're on it.</p>
                <p class="text-xs text-ink-muted">Report in your inbox within 48 hours.</p>
              </div>

              <div class="mt-4 pt-4 border-t border-rule/60 space-y-2">
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">No credit card</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">No sales call</span>
                </div>
                <div class="flex items-center gap-2">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M13.5 4.5L6.5 11.5L2.5 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-success" />
                  </svg>
                  <span class="text-[11px] text-ink-muted">Manually reviewed</span>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>

      <!-- Mobile form -->
      <div class="lg:hidden mt-16 rounded-xl border border-accent/20 bg-accent/5 px-6 py-8" data-reveal>
        <p class="text-xl font-bold tracking-tight mb-1">
          Want to know your score?
        </p>
        <p class="text-sm text-ink-secondary mb-5">
          Drop your URL — full report in 48 hours.
        </p>
        <form
          id="reports-form-mobile"
          class="flex flex-col gap-3"
          action={formspreeUrl}
          method="POST"
          aria-label="Request a free Roofing website audit"
        >
          <input type="hidden" name="_subject" value="Reports Page Audit Request (Mobile)" />
          <input type="text" name="_gotcha" style="display:none" />
          <input type="text" name="business_name" placeholder="Business name" required class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300" />
          <input type="text" name="website" placeholder="yoursite.com" required class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300" />
          <input type="email" name="email" placeholder="Email for report" required class="w-full px-4 py-3.5 rounded-lg bg-surface border border-rule text-ink placeholder-ink-faint text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-300" />
          <button type="submit" id="reports-submit-mobile" class="w-full px-5 py-3.5 rounded-lg bg-accent text-white text-sm font-semibold hover:bg-accent-hover transition-colors duration-300 cursor-pointer">
            Run My Free Audit
          </button>
        </form>
        <div id="reports-success-mobile" class="hidden text-center py-6">
          <p class="text-sm font-semibold mb-1">We're on it.</p>
          <p class="text-xs text-ink-muted">Report in your inbox within 48 hours.</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    function setupForm(formId: string, successId: string, submitId: string) {
      const form = document.getElementById(formId) as HTMLFormElement | null;
      const success = document.getElementById(successId);
      const btn = document.getElementById(submitId) as HTMLButtonElement | null;
      if (!form || !success || !btn) return;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        if (btn.disabled) return;
        btn.textContent = "Sending...";
        btn.disabled = true;
        try {
          const res = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: { Accept: "application/json" },
          });
          if (res.ok) {
            form.classList.add("hidden");
            success.classList.remove("hidden");
          } else {
            btn.textContent = "Something went wrong";
            btn.disabled = false;
            setTimeout(() => { btn.textContent = "Run My Free Audit"; }, 3000);
          }
        } catch {
          btn.textContent = "Something went wrong";
          btn.disabled = false;
          setTimeout(() => { btn.textContent = "Run My Free Audit"; }, 3000);
        }
      });
    }

    setupForm("reports-form", "reports-success", "reports-submit");
    setupForm("reports-form-mobile", "reports-success-mobile", "reports-submit-mobile");
  </script>
</Base>
