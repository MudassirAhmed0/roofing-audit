---
import Base from "../layouts/Base.astro";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Terms of Service — Roofing Audit",
    description: "Terms and conditions for using Roofing Audit's website and services.",
    url: "https://roofingaudit.co/terms/",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://roofingaudit.co" },
      { "@type": "ListItem", position: 2, name: "Terms of Service", item: "https://roofingaudit.co/terms/" },
    ],
  },
];
---

<Base
  title="Terms of Service — Roofing Audit"
  description="Terms and conditions for using Roofing Audit's website and services."
  jsonLd={jsonLd}
>
  <section class="pt-28 pb-20 sm:pt-32 sm:pb-28">
    <div class="px-6 md:px-12 lg:px-16">
      <div class="max-w-3xl">
        <div class="hero-reveal mb-10">
          <p class="font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
            Legal
          </p>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-[1.1]">
            Terms of Service
          </h1>
          <p class="mt-3 text-sm text-ink-muted font-mono">
            Last updated: March 6, 2026
          </p>
        </div>

        <div class="prose" data-reveal style="--delay:80ms">
          <p>
            By accessing or using roofingaudit.co ("the Site"), you agree to these terms. If you do not agree, do not use the Site.
          </p>

          <h2>Our Service</h2>
          <p>
            Roofing Audit provides free website audit reports for Roofing businesses. Our audits evaluate website performance, SEO, user experience, and lead generation potential. Reports are delivered via email within approximately 48 hours of a request.
          </p>

          <h2>Free Audit Reports</h2>
          <ul>
            <li>Audits are provided free of charge with no obligation</li>
            <li>Reports contain our professional assessment and recommendations — they are not guarantees of specific results</li>
            <li>We reserve the right to decline an audit request at our discretion</li>
            <li>Audit findings are based on publicly available information about your website at the time of the audit</li>
          </ul>

          <h2>Published Reports</h2>
          <p>
            We publish anonymized and non-anonymized audit reports on our Site for educational purposes. If your business is featured in a published report and you would like it removed, contact us at <a href="mailto:contact@roofingaudit.co">contact@roofingaudit.co</a> and we will remove it promptly.
          </p>

          <h2>Accuracy of Information</h2>
          <p>
            We make reasonable efforts to ensure the accuracy of our audit reports and blog content. However, website performance and SEO metrics change frequently. Information on the Site is provided "as is" without warranties of any kind.
          </p>
          <p>
            Statistics cited on the Site (such as average load times and audit scores) are based on our own research and audits of Roofing business websites and are accurate to the best of our knowledge at the time of publication.
          </p>

          <h2>Intellectual Property</h2>
          <p>
            All content on the Site — including text, graphics, logos, blog posts, and audit report formats — is the property of Roofing Audit and is protected by applicable intellectual property laws. You may not reproduce, distribute, or create derivative works from our content without written permission.
          </p>

          <h2>User Conduct</h2>
          <p>When using the Site, you agree not to:</p>
          <ul>
            <li>Submit false or misleading information through our forms</li>
            <li>Attempt to interfere with the Site's operation or security</li>
            <li>Use automated tools to scrape or extract content from the Site</li>
            <li>Submit audit requests for websites you do not own or have authority over</li>
          </ul>

          <h2>Limitation of Liability</h2>
          <p>
            Roofing Audit is not liable for any direct, indirect, incidental, or consequential damages arising from your use of the Site or reliance on our audit reports. Our recommendations are advisory in nature and implementing them is at your own discretion and risk.
          </p>

          <h2>External Links</h2>
          <p>
            The Site may contain links to third-party websites. We are not responsible for the content or practices of external sites.
          </p>

          <h2>Changes to These Terms</h2>
          <p>
            We may update these terms at any time. Continued use of the Site after changes constitutes acceptance of the updated terms.
          </p>

          <h2>Contact</h2>
          <p>
            Questions about these terms? Email us at <a href="mailto:contact@roofingaudit.co">contact@roofingaudit.co</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
