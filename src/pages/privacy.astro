---
import Base from "../layouts/Base.astro";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Privacy Policy — Roofing Audit",
    description: "How Roofing Audit collects, uses, and protects your information.",
    url: "https://roofingaudit.co/privacy/",
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: "https://roofingaudit.co" },
      { "@type": "ListItem", position: 2, name: "Privacy Policy", item: "https://roofingaudit.co/privacy/" },
    ],
  },
];
---

<Base
  title="Privacy Policy — Roofing Audit"
  description="How Roofing Audit collects, uses, and protects your information."
  jsonLd={jsonLd}
>
  <section class="pt-28 pb-20 sm:pt-32 sm:pb-28">
    <div class="px-6 md:px-12 lg:px-16">
      <div class="max-w-3xl">
        <div class="hero-reveal mb-10">
          <p class="font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
            Legal
          </p>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-[1.1]">
            Privacy Policy
          </h1>
          <p class="mt-3 text-sm text-ink-muted font-mono">
            Last updated: March 6, 2026
          </p>
        </div>

        <div class="prose" data-reveal style="--delay:80ms">
          <p>
            Roofing Audit ("we", "us", "our") operates roofingaudit.co. This page explains what information we collect, how we use it, and your rights regarding that information.
          </p>

          <h2>Information We Collect</h2>

          <h3>Information you provide</h3>
          <p>When you request a free audit through any form on our site, we collect:</p>
          <ul>
            <li>Business name</li>
            <li>Website URL</li>
            <li>Email address</li>
          </ul>
          <p>
            Form submissions are processed through <strong>Formspree</strong>, a third-party form handling service. Formspree's privacy policy applies to data processed through their service.
          </p>

          <h3>Information collected automatically</h3>
          <p>We use the following analytics tools to understand how visitors use our site:</p>
          <ul>
            <li><strong>Google Analytics (GA4)</strong> — collects anonymized usage data including pages visited, time on site, device type, and approximate geographic location. Google Analytics uses cookies.</li>
            <li><strong>Microsoft Clarity</strong> — records anonymized session replays and heatmaps to help us improve the user experience. Clarity may use cookies.</li>
          </ul>
          <p>
            Both analytics tools load after the page has fully rendered and do not affect site performance.
          </p>

          <h2>How We Use Your Information</h2>
          <ul>
            <li>To deliver your free Roofing website audit report via email</li>
            <li>To follow up regarding the audit if needed</li>
            <li>To improve our website and audit process based on aggregate analytics</li>
          </ul>
          <p>We do not sell, rent, or share your personal information with third parties for marketing purposes.</p>

          <h2>Cookies</h2>
          <p>
            Our site uses cookies through Google Analytics and Microsoft Clarity for analytics purposes only. You can disable cookies in your browser settings. The site will function normally without them.
          </p>

          <h2>Data Retention</h2>
          <p>
            We retain form submission data for as long as necessary to provide the requested audit and for reasonable follow-up. Analytics data is retained according to the default retention policies of Google Analytics and Microsoft Clarity.
          </p>

          <h2>Your Rights</h2>
          <p>You have the right to:</p>
          <ul>
            <li>Request access to the personal information we hold about you</li>
            <li>Request deletion of your personal information</li>
            <li>Opt out of analytics tracking by using browser privacy settings or extensions</li>
          </ul>

          <h2>Third-Party Services</h2>
          <p>We use the following third-party services:</p>
          <ul>
            <li><strong>Formspree</strong> — form submission processing</li>
            <li><strong>Google Analytics</strong> — website analytics</li>
            <li><strong>Microsoft Clarity</strong> — session analytics</li>
          </ul>
          <p>Each service has its own privacy policy governing how they handle data.</p>

          <h2>Changes to This Policy</h2>
          <p>
            We may update this policy from time to time. Changes will be reflected on this page with an updated "Last updated" date.
          </p>

          <h2>Contact</h2>
          <p>
            Questions about this policy? Email us at <a href="mailto:contact@roofingaudit.co">contact@roofingaudit.co</a>.
          </p>
        </div>
      </div>
    </div>
  </section>
</Base>
