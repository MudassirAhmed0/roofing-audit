---
import Base from "../../layouts/Base.astro";
import MarketBreadcrumb from "../../components/market/MarketBreadcrumb.astro";
import MarketReports from "../../components/market/MarketReports.astro";
import marketData from "../../data/market-data.json";

const siteUrl = "https://roofingaudit.co";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Roofing Market Reports",
    description: `Data-driven analysis of ${marketData.national?.totalLeads ?? 0} Roofing company websites across the United States.`,
    url: `${siteUrl}/market/`,
    dateModified: marketData.generatedAt,
    author: { "@type": "Organization", name: "Roofing Audit", url: siteUrl },
    publisher: { "@type": "Organization", name: "Roofing Audit", url: siteUrl, logo: { "@type": "ImageObject", url: `${siteUrl}/og-image.png`, width: 1200, height: 630 } },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Market Reports", item: `${siteUrl}/market/` },
    ],
  },
];
---

<Base
  title="Roofing Market Reports | Roofing Audit"
  description={`Data-driven analysis of ${marketData.national?.totalLeads ?? 0} Roofing company websites. Browse reports by state, city, or common website problems.`}
  jsonLd={jsonLd}
>
  <section class="pt-28 pb-12 sm:pt-32 sm:pb-16">
    <div class="px-6 md:px-12 lg:px-16">
      <MarketBreadcrumb items={[
        { name: "Home", href: "/" },
        { name: "Market Reports" },
      ]} />

      <p class="hero-reveal font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
        Market Reports
      </p>
      <h1 class="hero-reveal text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1]" style="--delay:60ms">
        Roofing Website Market Data
      </h1>
      <p class="hero-reveal mt-4 text-ink-secondary text-lg leading-relaxed max-w-2xl" style="--delay:120ms">
        We audited {marketData.national?.totalLeads ?? 0} Roofing company websites across {marketData.national?.stateCount ?? 0} states and {marketData.national?.cityCount ?? 0} cities. Explore the data below.
      </p>
    </div>
  </section>

  <section class="pb-16">
    <div class="px-6 md:px-12 lg:px-16 space-y-12">
      <!-- National Report -->
      <div data-reveal>
        <h2 class="text-lg font-bold tracking-tight mb-4">National Report</h2>
        <a
          href="/market/roofing/"
          class="block rounded-sm border border-rule bg-surface-alt/60 p-6 hover:border-accent/40 transition-colors"
        >
          <p class="text-xl font-bold text-ink mb-1">Roofing Website Report: {marketData.national?.totalLeads ?? 0} Sites Analyzed</p>
          <p class="text-sm text-ink-secondary">
            Average Roofing Website Index score: {marketData.national?.avgDeepScore ?? 0}/100. Only {Math.round(marketData.national?.bookingRate ?? 0 * 100)}% offer online booking.
          </p>
          <p class="text-xs text-accent mt-2">View full report →</p>
        </a>
      </div>

      <!-- States -->
      <div data-reveal style="--delay:100ms">
        <h2 class="text-lg font-bold tracking-tight mb-4">By State</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {marketData.states.map((state) => (
            <a
              href={`/market/roofing/${state.slug}/`}
              class="rounded-sm border border-rule bg-surface-alt/60 p-5 hover:border-accent/40 transition-colors"
            >
              <p class="font-bold text-ink">{state.stateName}</p>
              <p class="text-xs text-ink-muted mt-1">{state.totalLeads} sites audited · Score: {state.avgDeepScore}/100</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Cities -->
      <div data-reveal style="--delay:200ms">
        <h2 class="text-lg font-bold tracking-tight mb-4">By City</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {marketData.cities.map((city) => (
            <a
              href={`/market/roofing/${city.slug}/`}
              class="rounded-sm border border-rule bg-surface-alt/60 p-4 hover:border-accent/40 transition-colors"
            >
              <p class="font-semibold text-ink text-sm">{city.city}, {city.state}</p>
              <p class="text-xs text-ink-muted mt-0.5">{city.totalLeads} sites · {city.avgDeepScore}/100</p>
            </a>
          ))}
        </div>
      </div>

      <!-- Problems -->
      <div data-reveal style="--delay:300ms">
        <h2 class="text-lg font-bold tracking-tight mb-4">By Website Problem</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {marketData.problems.map((problem) => (
            <a
              href={`/market/roofing/${problem.slug}/`}
              class="rounded-sm border border-rule bg-surface-alt/60 p-4 hover:border-accent/40 transition-colors"
            >
              <p class="font-semibold text-ink text-sm">{problem.gap}</p>
              <p class="text-xs text-ink-muted mt-0.5">{Math.round(problem.nationalFrequency * 100)}% of Roofing sites affected</p>
            </a>
          ))}
        </div>
      </div>
      <!-- Featured Audit Reports -->
      <div data-reveal style="--delay:400ms">
        <MarketReports
          heading="Featured Audit Reports"
          subheading="Real Roofing website audits with full diagnostics, gap analysis, and revenue impact."
          limit={3}
        />
      </div>
    </div>
  </section>
</Base>
