        {/* State Breakdown */}
        <section data-reveal class="py-8 border-t border-rule">
          <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-6">Frequency by State</h2>
          <div class="space-y-3 max-w-xl">
            {p.byState.map((st) => {
              const stPct = Math.round(st.frequency * 100);
              return (
                <div class="flex items-center gap-3">
                  <a href={`/market/roofing/${p.slug}/${st.slug}/`} class="w-24 text-sm text-accent hover:text-accent-hover transition-colors flex-none">
                    {st.stateName}
                  </a>
                  <div class="flex-1 h-5 rounded bg-surface relative overflow-hidden">
                    <div class="h-full rounded bg-accent/70" style={`width: ${stPct}%`} />
