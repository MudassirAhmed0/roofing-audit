})()}

{/* ═══════════════════════════════════════════
    PROBLEM × STATE PAGE
    ═══════════════════════════════════════════ */}
{type === "problem-state" && problem && problemState && (() => {
  const p = problem;
  const ps = problemState;
  const narrative = gapNarratives[p.slug];
  const pct = Math.round(ps.frequency * 100);
  const nationalPct = Math.round(p.nationalFrequency * 100);
  const delta = pct - nationalPct;
  const deltaLabel = delta > 0 ? `+${delta}` : `${delta}`;
  const deltaColor = delta > 0 ? "text-danger" : delta < 0 ? "text-success" : "text-ink-muted";

  const description = `${pct}% of ${ps.stateName} Roofing websites have ${p.gap.toLowerCase()}. ${delta > 0 ? "Worse" : "Better"} than the ${nationalPct}% national average.`;

  const jsonLd = [
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `${pct}% of ${ps.stateName} Roofing Sites: ${p.gap}`,
      description,
      url: `${siteUrl}/market/roofing/${p.slug}/${ps.slug}/`,
      dateModified: marketData.generatedAt,
      author: { "@type": "Organization", name: "Roofing Audit", url: siteUrl },
      publisher: { "@type": "Organization", name: "Roofing Audit", url: siteUrl, logo: { "@type": "ImageObject", url: `${siteUrl}/og-image.png`, width: 1200, height: 630 } },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Market Reports", item: `${siteUrl}/market/` },
        { "@type": "ListItem", position: 3, name: "Roofing", item: `${siteUrl}/market/roofing/` },
        { "@type": "ListItem", position: 4, name: p.gap, item: `${siteUrl}/market/roofing/${p.slug}/` },
        { "@type": "ListItem", position: 5, name: ps.stateName, item: `${siteUrl}/market/roofing/${p.slug}/${ps.slug}/` },
      ],
    },
  ];

  // Cities in this state for this problem
  const stateCities = p.byCity
    .filter((bc) => bc.state === ps.state)
    .sort((a, b) => b.frequency - a.frequency);

  return (
    <Base
      title={`${pct}% of ${ps.stateName} Roofing Sites: ${p.gap}`}
      description={description}
      jsonLd={jsonLd}
    >
      <div class="px-6 md:px-12 lg:px-16">
        <div class="pt-28 sm:pt-32">
          <MarketBreadcrumb items={[
            { name: "Home", href: "/" },
            { name: "Market Reports", href: "/market/" },
            { name: "Roofing", href: "/market/roofing/" },
            { name: p.gap, href: `/market/roofing/${p.slug}/` },
            { name: ps.stateName },
          ]} />
        </div>
      </div>

      <MarketHero
        pretitle={`${ps.stateName} · ${p.gap}`}
        title={`<span class="text-accent">${pct}%</span> of ${ps.stateName} Roofing Websites Have ${p.gap}`}
        subtitle={`That's ${ps.count} of ${ps.deepTotal} audited sites in ${ps.stateName} — ${deltaLabel} percentage points vs. the national rate of ${nationalPct}%.`}
        totalAudited={ps.deepTotal}
        lastUpdated={marketData.generatedAt}
      />

      <div class="px-6 md:px-12 lg:px-16 space-y-2">
        {/* Delta Card */}
        <section data-reveal class="pb-6">
          <div class="rounded-xl border border-rule bg-surface-alt/60 p-5 inline-flex items-baseline gap-3">
            <span class="text-sm text-ink-secondary">{ps.stateName} vs. National:</span>
            <span class={`text-2xl font-bold ${deltaColor}`}>{deltaLabel}pp</span>
            <span class="text-xs text-ink-muted">{delta > 0 ? "worse" : delta < 0 ? "better" : "same"} than national average</span>
          </div>
        </section>

        {/* Why it matters */}
        {narrative && (
          <section data-reveal class="py-8 border-t border-rule">
            <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-4">Impact in {ps.stateName}</h2>
            <p class="text-ink-secondary leading-relaxed max-w-3xl">
              {interpolate(narrative.costLine, { market: ps.stateName, pct, count: ps.count })}
            </p>
          </section>
        )}

        {/* City Breakdown */}
        {stateCities.length > 0 && (
          <section data-reveal class="py-8 border-t border-rule">
            <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-6">City Breakdown in {ps.stateName}</h2>
            <div class="overflow-x-auto -mx-6 px-6 md:mx-0 md:px-0">
              <table class="w-full text-sm min-w-[400px]">
                <thead>
                  <tr class="border-b-2 border-rule">
                    <th class="text-left py-3 pr-4 text-ink font-semibold">City</th>
                    <th class="text-right py-3 px-3 text-ink font-semibold">Frequency</th>
                    <th class="text-right py-3 pl-3 text-ink font-semibold">Affected</th>
                  </tr>
                </thead>
                <tbody>
                  {stateCities.map((sc) => {
                    const scPct = Math.round(sc.frequency * 100);
                    const isWorst = scPct >= pct;
                    return (
                      <tr class="border-b border-rule/60 hover:bg-surface-alt/40">
                        <td class="py-3 pr-4">
                          <a href={`/market/roofing/${sc.slug}/`} class="text-accent hover:text-accent-hover transition-colors">{sc.city}</a>
                        </td>
                        <td class={`text-right py-3 px-3 font-mono text-xs ${isWorst ? "text-danger" : "text-success"}`}>{scPct}%</td>
                        <td class="text-right py-3 pl-3 font-mono text-xs text-ink-secondary">{sc.count} of {sc.deepTotal}</td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {/* Links */}
        <section data-reveal class="py-8 border-t border-rule">
          <div class="flex flex-wrap gap-3">
            <a href={`/market/roofing/${p.slug}/`} class="rounded-lg border border-rule bg-surface-alt/60 px-4 py-2 text-sm text-accent hover:border-accent/40 transition-colors">
              ← National {p.gap} Report
            </a>
            <a href={`/market/roofing/${ps.slug}/`} class="rounded-lg border border-rule bg-surface-alt/60 px-4 py-2 text-sm text-accent hover:border-accent/40 transition-colors">
              {ps.stateName} Roofing Report →
            </a>
          </div>
        </section>

        {/* Reports from this state with this problem */}
        <MarketReports
          state={ps.state}
          gapMatch={p.gap.split(" ").slice(0, 3).join(" ")}
          heading={`${ps.stateName} Reports with ${p.gap}`}
          subheading={`Roofing websites in ${ps.stateName} where this issue was found.`}
          limit={6}
        />

        <MarketCTA market={ps.stateName} />
      </div>
    </Base>
  );
})()}
