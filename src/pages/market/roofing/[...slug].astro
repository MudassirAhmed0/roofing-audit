        <section data-reveal class="py-8 border-t border-rule">
          <h2 class="text-lg font-bold tracking-tight mb-4">Related Problems</h2>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {marketData.problems
              .filter((rp) => rp.slug !== p.slug)
              .slice(0, 6)
              .map((rp) => (
                <a
                  href={`/market/roofing/${rp.slug}/`}
