                    <td class="py-3 pr-4">
                      <a href={`/market/roofing/${wc.slug}/`} class="text-accent hover:text-accent-hover transition-colors">{wc.city}, {wc.state}</a>
                    </td>
                    <td class="text-right py-3 px-3 font-mono text-xs text-danger">{Math.round(wc.frequency * 100)}%</td>
                    <td class="text-right py-3 pl-3 font-mono text-xs text-ink-secondary">{wc.count} of {wc.deepTotal}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        {/* Best Markets */}
        <section data-reveal class="py-8 border-t border-rule">
          <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-6">Best Markets for {p.gap}</h2>
          <div class="overflow-x-auto -mx-6 px-6 md:mx-0 md:px-0">
            <table class="w-full text-sm min-w-[400px]">
              <thead>
                <tr class="border-b-2 border-rule">
                  <th class="text-left py-3 pr-4 text-ink font-semibold">City</th>
                  <th class="text-right py-3 px-3 text-ink font-semibold">Frequency</th>
