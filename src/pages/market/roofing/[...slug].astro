---
import Base from "../../../layouts/Base.astro";
import MarketBreadcrumb from "../../../components/market/MarketBreadcrumb.astro";
import MarketHero from "../../../components/market/MarketHero.astro";
import StatCards from "../../../components/market/StatCards.astro";
import ScoreDistribution from "../../../components/market/ScoreDistribution.astro";
import GapSection from "../../../components/market/GapSection.astro";
import ComparisonTable from "../../../components/market/ComparisonTable.astro";
import Methodology from "../../../components/market/Methodology.astro";
import MarketCTA from "../../../components/market/MarketCTA.astro";
import MarketReports from "../../../components/market/MarketReports.astro";
import marketData from "../../../data/market-data.json";
import { gapNarratives, interpolate } from "../../../data/gap-narratives";

const siteUrl = "https://roofingaudit.co";

export function getStaticPaths() {
  const paths: any[] = [];

  // States: /market/roofing/texas/
  for (const state of marketData.states) {
    paths.push({
      params: { slug: state.slug },
      props: { type: "state" as const, state, city: null, problem: null, problemState: null },
    });
  }

  // Cities: /market/roofing/houston-tx/
  for (const city of marketData.cities) {
    paths.push({
      params: { slug: city.slug },
      props: { type: "city" as const, state: null, city, problem: null, problemState: null },
    });
  }

  // Problems: /market/roofing/no-online-scheduling/
  for (const problem of marketData.problems) {
    paths.push({
      params: { slug: problem.slug },
      props: { type: "problem" as const, state: null, city: null, problem, problemState: null },
    });
  }

  // Problem x State: /market/roofing/no-online-scheduling/texas/
  for (const problem of marketData.problems) {
    for (const st of problem.byState) {
      if (st.count >= 10) {
        const stateData = marketData.states.find((s) => s.slug === st.slug);
        paths.push({
          params: { slug: `${problem.slug}/${st.slug}` },
          props: { type: "problem-state" as const, state: stateData || null, city: null, problem, problemState: st },
        });
      }
    }
  }

  return paths;
}

const { type, state, city, problem, problemState } = Astro.props;
---

{/* ═══════════════════════════════════════════
    STATE PAGE
    ═══════════════════════════════════════════ */}
{type === "state" && state && (() => {
  const s = state;
  const topGaps = s.topGaps.slice(0, 3);

  const stats = [
    { label: "Roofing Website Index", value: `${s.avgDeepScore}/100`, detail: `Median: ${s.medianDeepScore}` },
    { label: "Avg Load Speed", value: `${s.avgSpeed}s` },
    { label: "Online Booking", value: `${Math.round(s.bookingRate * 100)}%` },
    { label: "SSL Secured", value: `${Math.round(s.sslRate * 100)}%` },
    { label: "Reviews Displayed", value: `${Math.round(s.reviewsDisplayedRate * 100)}%` },
    { label: "Contact Form", value: `${Math.round(s.contactFormRate * 100)}%` },
  ];

  const cityRows = marketData.cities
    .filter((c) => c.state === s.state)
    .map((c) => ({
      name: c.city,
      slug: c.slug,
      leads: c.totalLeads,
      score: c.avgDeepScore,
      speed: c.avgSpeed,
      booking: c.bookingRate,
      ssl: c.sslRate,
      reviews: c.reviewsDisplayedRate,
    }));

  const description = `${s.stateName} Roofing websites score ${s.avgDeepScore} on the Roofing Website Index. ${Math.round(s.bookingRate * 100)}% have online booking.`;

  const jsonLd = [
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `${s.stateName} Roofing Websites: ${s.totalLeads} Audited`,
      description,
      url: `${siteUrl}/market/roofing/${s.slug}/`,
      dateModified: marketData.generatedAt,
      author: { "@type": "Organization", name: "Roofing Audit", url: siteUrl },
      publisher: { "@type": "Organization", name: "Roofing Audit", url: siteUrl, logo: { "@type": "ImageObject", url: `${siteUrl}/og-image.png`, width: 1200, height: 630 } },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Market Reports", item: `${siteUrl}/market/` },
        { "@type": "ListItem", position: 3, name: "Roofing", item: `${siteUrl}/market/roofing/` },
        { "@type": "ListItem", position: 4, name: s.stateName, item: `${siteUrl}/market/roofing/${s.slug}/` },
      ],
    },
  ];

  const scoreDelta = s.vsNational?.scoreDelta ?? 0;
  const deltaLabel = scoreDelta > 0 ? `+${scoreDelta}` : `${scoreDelta}`;
  const deltaColor = scoreDelta > 0 ? "text-success" : scoreDelta < 0 ? "text-danger" : "text-ink-muted";

  return (
    <Base
      title={`${s.stateName} Roofing Websites: ${s.totalLeads} Audited | Roofing Audit`}
      description={description}
      jsonLd={jsonLd}
    >
      <div class="px-6 md:px-12 lg:px-16">
        <div class="pt-28 sm:pt-32">
          <MarketBreadcrumb items={[
            { name: "Home", href: "/" },
            { name: "Market Reports", href: "/market/" },
            { name: "Roofing", href: "/market/roofing/" },
            { name: s.stateName },
          ]} />
        </div>
      </div>

      <MarketHero
        pretitle={`${s.stateName} Roofing Report`}
        title={`Roofing Websites in <span class="text-accent">${s.stateName}</span>: ${s.totalLeads} Sites Audited`}
        subtitle={`${s.stateName} Roofing websites average ${s.avgDeepScore}/100 on the Roofing Website Index — ${deltaLabel} points vs. the national average.`}
        totalAudited={s.totalLeads}
        lastUpdated={marketData.generatedAt}
      />

      <div class="px-6 md:px-12 lg:px-16 space-y-2">
        {/* State vs National delta card */}
        <section data-reveal class="pb-6">
          <div class="rounded-xl border border-rule bg-surface-alt/60 p-5 inline-flex items-baseline gap-3">
            <span class="text-sm text-ink-secondary">{s.stateName} vs. National:</span>
            <span class={`text-2xl font-bold ${deltaColor}`}>{deltaLabel}</span>
            <span class="text-xs text-ink-muted">points on the Index</span>
          </div>
        </section>

        {/* State Snapshot */}
        <section data-reveal class="pb-8">
          <h2 class="text-lg font-bold tracking-tight mb-4">{s.stateName} Snapshot</h2>
          <StatCards stats={stats} />
        </section>

        {/* Key Finding #1 */}
        {topGaps[0] && (() => {
          const gap = topGaps[0];
          const narrative = gapNarratives[gap.slug];
          if (!narrative) return null;
          const vars = { market: s.stateName, pct: Math.round(gap.frequency * 100), count: gap.count };
          return (
            <GapSection
              heading={interpolate(narrative.heading, vars)}
              frequency={gap.frequency}
              count={gap.count}
              total={s.deepAudited}
              severity={gap.severity}
              whyItMatters={interpolate(narrative.whyItMatters, vars)}
              whatTopSitesDo={interpolate(narrative.whatTopSitesDo, vars)}
              costLine={interpolate(narrative.costLine, vars)}
              problemSlug={gap.slug}
            />
          );
        })()}

        {/* City Rankings */}
        {cityRows.length > 0 && (
          <section data-reveal class="py-8 border-t border-rule">
            <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-6">City Rankings in {s.stateName}</h2>
            <ComparisonTable rows={cityRows} />
          </section>
        )}

        {/* Key Finding #2 */}
        {topGaps[1] && (() => {
          const gap = topGaps[1];
          const narrative = gapNarratives[gap.slug];
          if (!narrative) return null;
          const vars = { market: s.stateName, pct: Math.round(gap.frequency * 100), count: gap.count };
          return (
            <GapSection
              heading={interpolate(narrative.heading, vars)}
              frequency={gap.frequency}
              count={gap.count}
              total={s.deepAudited}
              severity={gap.severity}
              whyItMatters={interpolate(narrative.whyItMatters, vars)}
              whatTopSitesDo={interpolate(narrative.whatTopSitesDo, vars)}
              costLine={interpolate(narrative.costLine, vars)}
              problemSlug={gap.slug}
            />
          );
        })()}

        {/* Score Distribution */}
        {s.scoreDistribution && (
        <section class="py-8">
          <ScoreDistribution
            distribution={s.scoreDistribution}
            avgScore={s.avgDeepScore}
            medianScore={s.medianDeepScore}
            bestScore={s.bestScore}
            worstScore={s.worstScore}
          />
        </section>
        )}

        {/* Key Finding #3 */}
        {topGaps[2] && (() => {
          const gap = topGaps[2];
          const narrative = gapNarratives[gap.slug];
          if (!narrative) return null;
          const vars = { market: s.stateName, pct: Math.round(gap.frequency * 100), count: gap.count };
          return (
            <GapSection
              heading={interpolate(narrative.heading, vars)}
              frequency={gap.frequency}
              count={gap.count}
              total={s.deepAudited}
              severity={gap.severity}
              whyItMatters={interpolate(narrative.whyItMatters, vars)}
              whatTopSitesDo={interpolate(narrative.whatTopSitesDo, vars)}
              costLine={interpolate(narrative.costLine, vars)}
              problemSlug={gap.slug}
            />
          );
        })()}

        {/* Methodology */}
        <Methodology
          totalLeads={s.totalLeads}
          deepAudited={s.deepAudited}
          lastUpdated={marketData.generatedAt}
        />

        {/* Explore Cities */}
        <section data-reveal class="py-8 border-t border-rule">
          <h2 class="text-lg font-bold tracking-tight mb-4">Explore {s.stateName} Cities</h2>
          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {marketData.cities.filter((c) => c.state === s.state).map((c) => (
              <a
                href={`/market/roofing/${c.slug}/`}
                class="rounded-xl border border-rule bg-surface-alt/60 p-4 hover:border-accent/40 transition-colors"
              >
                <p class="font-semibold text-ink text-sm">{c.city}</p>
                <p class="text-xs text-ink-muted mt-0.5">{c.totalLeads} sites · {c.avgDeepScore}/100</p>
              </a>
            ))}
          </div>
        </section>

        {/* Audit Reports from this state */}
        <MarketReports state={s.state} heading={`Roofing Audit Reports from ${s.stateName}`} />

        <MarketCTA market={s.stateName} />
      </div>
    </Base>
  );
})()}

{/* ═══════════════════════════════════════════
    CITY PAGE
    ═══════════════════════════════════════════ */}
{type === "city" && city && (() => {
  const c = city;
  const topGaps = c.topGaps.slice(0, 3);
  const stateData = marketData.states.find((s) => s.state === c.state);
  const n = marketData.national;

  const stats = [
    { label: "Roofing Website Index", value: `${c.avgDeepScore}/100`, detail: `Median: ${c.medianDeepScore}` },
    { label: "Avg Load Speed", value: `${c.avgSpeed}s` },
    { label: "Online Booking", value: `${Math.round(c.bookingRate * 100)}%` },
    { label: "SSL Secured", value: `${Math.round(c.sslRate * 100)}%` },
    { label: "Reviews Displayed", value: `${Math.round(c.reviewsDisplayedRate * 100)}%` },
    { label: "Contact Form", value: `${Math.round(c.contactFormRate * 100)}%` },
  ];

  const topGapStatement = topGaps[0]
    ? `${Math.round(topGaps[0].frequency * 100)}% lack ${topGaps[0].gap.toLowerCase()}`
    : "";
  const description = `We audited ${c.totalLeads} Roofing websites in ${c.city}. ${topGapStatement}. See how ${c.city} compares.`;

  const jsonLd = [
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `${c.city} Roofing Websites: ${c.totalLeads} Audited`,
      description,
      url: `${siteUrl}/market/roofing/${c.slug}/`,
      dateModified: marketData.generatedAt,
      author: { "@type": "Organization", name: "Roofing Audit", url: siteUrl },
      publisher: { "@type": "Organization", name: "Roofing Audit", url: siteUrl, logo: { "@type": "ImageObject", url: `${siteUrl}/og-image.png`, width: 1200, height: 630 } },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Market Reports", item: `${siteUrl}/market/` },
        { "@type": "ListItem", position: 3, name: "Roofing", item: `${siteUrl}/market/roofing/` },
        { "@type": "ListItem", position: 4, name: c.stateName, item: `${siteUrl}/market/roofing/${stateData?.slug || ""}/` },
        { "@type": "ListItem", position: 5, name: c.city, item: `${siteUrl}/market/roofing/${c.slug}/` },
      ],
    },
  ];

  // Three-way comparison rows
  const threeWay = [
    { metric: "Website Index", city: `${c.avgDeepScore}`, state: stateData ? `${stateData.avgDeepScore}` : "—", national: `${n.avgDeepScore}` },
    { metric: "Avg Speed", city: `${c.avgSpeed}s`, state: stateData ? `${stateData.avgSpeed}s` : "—", national: `${n.avgSpeed}s` },
    { metric: "Online Booking", city: `${Math.round(c.bookingRate * 100)}%`, state: stateData ? `${Math.round(stateData.bookingRate * 100)}%` : "—", national: `${Math.round(n.bookingRate * 100)}%` },
    { metric: "SSL Secured", city: `${Math.round(c.sslRate * 100)}%`, state: stateData ? `${Math.round(stateData.sslRate * 100)}%` : "—", national: `${Math.round(n.sslRate * 100)}%` },
    { metric: "Reviews Displayed", city: `${Math.round(c.reviewsDisplayedRate * 100)}%`, state: stateData ? `${Math.round(stateData.reviewsDisplayedRate * 100)}%` : "—", national: `${Math.round(n.reviewsDisplayedRate * 100)}%` },
    { metric: "Contact Form", city: `${Math.round(c.contactFormRate * 100)}%`, state: stateData ? `${Math.round(stateData.contactFormRate * 100)}%` : "—", national: `${Math.round(n.contactFormRate * 100)}%` },
  ];

  const nearbyRows = (c.nearbyCities || []).map((nc) => ({
    name: nc.city,
    slug: nc.slug,
    leads: nc.totalLeads,
    score: nc.avgDeepScore,
    speed: nc.avgSpeed,
    booking: nc.bookingRate,
    ssl: nc.sslRate,
    reviews: 0,
  }));

  return (
    <Base
      title={`${c.city} Roofing Websites: ${c.totalLeads} Audited | Roofing Audit`}
      description={description}
      jsonLd={jsonLd}
    >
      <div class="px-6 md:px-12 lg:px-16">
        <div class="pt-28 sm:pt-32">
          <MarketBreadcrumb items={[
            { name: "Home", href: "/" },
            { name: "Market Reports", href: "/market/" },
            { name: "Roofing", href: "/market/roofing/" },
            { name: c.stateName, href: `/market/roofing/${stateData?.slug || ""}/` },
            { name: c.city },
          ]} />
        </div>
      </div>

      <MarketHero
        pretitle={`${c.city}, ${c.state} Roofing Report`}
        title={`We Audited ${c.totalLeads} Roofing Websites in <span class="text-accent">${c.city}</span>, ${c.stateName}`}
        subtitle={`${c.city} Roofing websites score ${c.avgDeepScore}/100 on the Roofing Website Index. ${topGapStatement ? topGapStatement.charAt(0).toUpperCase() + topGapStatement.slice(1) + "." : ""}`}
        totalAudited={c.totalLeads}
        lastUpdated={marketData.generatedAt}
      />

      <div class="px-6 md:px-12 lg:px-16 space-y-2">
        {/* Market Snapshot */}
        <section data-reveal class="pb-8">
          <h2 class="text-lg font-bold tracking-tight mb-4">Market Snapshot</h2>
          <StatCards stats={stats} />
        </section>

        {/* Key Finding #1 */}
        {topGaps[0] && (() => {
          const gap = topGaps[0];
          const narrative = gapNarratives[gap.slug];
          if (!narrative) return null;
          const vars = { market: c.city, pct: Math.round(gap.frequency * 100), count: gap.count };
          return (
            <GapSection
              heading={interpolate(narrative.heading, vars)}
              frequency={gap.frequency}
              count={gap.count}
              total={c.deepAudited}
              severity={gap.severity}
              whyItMatters={interpolate(narrative.whyItMatters, vars)}
              whatTopSitesDo={interpolate(narrative.whatTopSitesDo, vars)}
              costLine={interpolate(narrative.costLine, vars)}
              problemSlug={gap.slug}
            />
          );
        })()}

        {/* Score Distribution */}
        {c.scoreDistribution && (
        <section class="py-8">
          <ScoreDistribution
            distribution={c.scoreDistribution}
            avgScore={c.avgDeepScore}
            medianScore={c.medianDeepScore}
            bestScore={c.bestScore}
            worstScore={c.worstScore}
          />
          <p class="text-xs text-ink-faint mt-3">
            The highest-scoring Roofing website in {c.city} earned a {c.bestScore} on the Roofing Website Index.
            The lowest scored {c.worstScore}.
          </p>
        </section>
        )}

        {/* Key Finding #2 */}
        {topGaps[1] && (() => {
          const gap = topGaps[1];
          const narrative = gapNarratives[gap.slug];
          if (!narrative) return null;
          const vars = { market: c.city, pct: Math.round(gap.frequency * 100), count: gap.count };
          return (
            <GapSection
              heading={interpolate(narrative.heading, vars)}
              frequency={gap.frequency}
              count={gap.count}
              total={c.deepAudited}
              severity={gap.severity}
              whyItMatters={interpolate(narrative.whyItMatters, vars)}
              whatTopSitesDo={interpolate(narrative.whatTopSitesDo, vars)}
              costLine={interpolate(narrative.costLine, vars)}
              problemSlug={gap.slug}
            />
          );
        })()}

        {/* Key Finding #3 */}
        {topGaps[2] && (() => {
          const gap = topGaps[2];
          const narrative = gapNarratives[gap.slug];
          if (!narrative) return null;
          const vars = { market: c.city, pct: Math.round(gap.frequency * 100), count: gap.count };
          return (
            <GapSection
              heading={interpolate(narrative.heading, vars)}
              frequency={gap.frequency}
              count={gap.count}
              total={c.deepAudited}
              severity={gap.severity}
              whyItMatters={interpolate(narrative.whyItMatters, vars)}
              whatTopSitesDo={interpolate(narrative.whatTopSitesDo, vars)}
              costLine={interpolate(narrative.costLine, vars)}
              problemSlug={gap.slug}
            />
          );
        })()}

        {/* Nearby Cities Comparison */}
        {nearbyRows.length > 0 && (
          <section data-reveal class="py-8 border-t border-rule">
            <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-6">How {c.city} Compares to Nearby Cities</h2>
            <ComparisonTable rows={[
              { name: c.city, slug: c.slug, leads: c.totalLeads, score: c.avgDeepScore, speed: c.avgSpeed, booking: c.bookingRate, ssl: c.sslRate, reviews: c.reviewsDisplayedRate },
              ...nearbyRows,
            ]} highlightSlug={c.slug} />
          </section>
        )}

        {/* Three-way comparison */}
        {stateData && (
          <section data-reveal class="py-8 border-t border-rule">
            <h2 class="text-xl sm:text-2xl font-bold tracking-tight mb-6">{c.city} vs. {c.stateName} vs. National</h2>
            <div class="overflow-x-auto -mx-6 px-6 md:mx-0 md:px-0">
              <table class="w-full text-sm min-w-[400px]">
                <thead>
                  <tr class="border-b-2 border-rule">
                    <th class="text-left py-3 pr-4 text-ink font-semibold">Metric</th>
                    <th class="text-right py-3 px-3 text-accent font-semibold">{c.city}</th>
                    <th class="text-right py-3 px-3 text-ink font-semibold">{c.stateName}</th>
                    <th class="text-right py-3 pl-3 text-ink font-semibold">National</th>
                  </tr>
                </thead>
                <tbody>
                  {threeWay.map((row) => (
                    <tr class="border-b border-rule/60 hover:bg-surface-alt/40">
                      <td class="py-3 pr-4 text-ink-secondary">{row.metric}</td>
                      <td class="text-right py-3 px-3 font-mono text-xs text-accent">{row.city}</td>
                      <td class="text-right py-3 px-3 font-mono text-xs text-ink-secondary">{row.state}</td>
                      <td class="text-right py-3 pl-3 font-mono text-xs text-ink-secondary">{row.national}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {/* Audit Reports from this city */}
        <MarketReports
          city={c.city}
          state={c.state}
          heading={`Roofing Audit Reports from ${c.city}`}
          subheading={`Real website audits from Roofing companies in ${c.city}, ${c.stateName}.`}
        />

        {/* Sample size disclosure */}
        <div data-reveal class="py-4 text-xs text-ink-faint font-mono">
          Performance data based on {c.totalLeads} Roofing websites.
          Quality scores based on {c.deepAudited} in-depth audits.
        </div>

        <MarketCTA market={c.city} />
      </div>
    </Base>
  );
})()}

{/* ═══════════════════════════════════════════
    PROBLEM PAGE
    ═══════════════════════════════════════════ */}
{type === "problem" && problem && (() => {
  const p = problem;
  const narrative = gapNarratives[p.slug];
  const pct = Math.round(p.nationalFrequency * 100);
  const n = marketData.national;

  const description = `${pct}% of Roofing websites have ${p.gap.toLowerCase()}. ${p.worstCity?.city || ""} is the worst market.`;

  const jsonLd = [
    {
      "@context": "https://schema.org",
      "@type": "WebPage",
      name: `${pct}% of Roofing Sites: ${p.gap}`,
      description,
      url: `${siteUrl}/market/roofing/${p.slug}/`,
      dateModified: marketData.generatedAt,
      author: { "@type": "Organization", name: "Roofing Audit", url: siteUrl },
      publisher: { "@type": "Organization", name: "Roofing Audit", url: siteUrl, logo: { "@type": "ImageObject", url: `${siteUrl}/og-image.png`, width: 1200, height: 630 } },
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Market Reports", item: `${siteUrl}/market/` },
        { "@type": "ListItem", position: 3, name: "Roofing", item: `${siteUrl}/market/roofing/` },
        { "@type": "ListItem", position: 4, name: p.gap, item: `${siteUrl}/market/roofing/${p.slug}/` },
      ],
    },
  ];

  const sortedByCity = [...p.byCity].sort((a, b) => b.frequency - a.frequency);
  const worstCities = sortedByCity.slice(0, 5);
  const bestCities = [...p.byCity].sort((a, b) => a.frequency - b.frequency).slice(0, 5);

  return (
    <Base
      title={`${pct}% of Roofing Sites: ${p.gap} | Roofing Audit`}
      description={description}
      jsonLd={jsonLd}
    >
      <div class="px-6 md:px-12 lg:px-16">
        <div class="pt-28 sm:pt-32">
