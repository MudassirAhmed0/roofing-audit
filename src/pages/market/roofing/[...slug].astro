                  <tr class="border-b border-rule/60 hover:bg-surface-alt/40">
                    <td class="py-3 pr-4">
                      <a href={`/market/roofing/${bc.slug}/`} class="text-accent hover:text-accent-hover transition-colors">{bc.city}, {bc.state}</a>
