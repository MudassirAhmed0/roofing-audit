---
const audits = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: "Page Speed",
    description: "Full Lighthouse audit. Load time, time to interactive, largest contentful paint. We measure everything Google measures.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18"/></svg>`,
    title: "Mobile Experience",
    description: "Over 60% of your customers search on mobile. We test tap targets, responsive layout, and mobile page speed separately.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
    title: "SEO Health",
    description: "Meta tags, structured data, local schema markup, sitemap, robots.txt. Everything that helps Google find and rank your business.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    title: "SSL & Security",
    description: "HTTPS status, security headers, mixed content warnings. Chrome labels insecure sites — that kills trust instantly.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    title: "CTA Clarity",
    description: "Is there a clear 'Book Now' or 'Call Us' above the fold? We check every page for conversion-driving actions.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: "Review Integration",
    description: "Your 4.8-star Google rating should be on your website. We check if reviews are displayed, linked, and driving trust.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72"/></svg>`,
    title: "Contact Access",
    description: "Phone number visible and clickable. Contact form working. Map embedded. We test every way a customer can reach you.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    title: "Competitor Gap",
    description: "We scan your top 3 local competitors and show you exactly where they're beating you — and where you can overtake them.",
  },
];
---

<section
  class="section-over-hero bg-surface py-20 md:py-44 px-6 md:px-12 lg:px-16 border-t border-rule"

  aria-labelledby="audit-heading"
>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-16 md:mb-24">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
        What We Check
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        id="audit-heading"
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl font-bold leading-[0.95] tracking-tight"
      >
        8-point diagnostic.<br class="hidden md:block" />
        <span class="text-accent">Zero guesswork.</span>
      </h2>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
    {
      audits.map((audit, i) => (
        <div
          data-reveal
          style={`--delay: ${i * 80}ms`}
          class="group border border-rule p-8 md:p-9 -mt-px -ml-px hover:bg-surface-card transition-colors duration-300"
        >
          <div class="flex items-center gap-4 mb-6">
            <span class="text-[10px] font-mono text-ink-faint">0{i + 1}</span>
            <div class="text-accent opacity-60 group-hover:opacity-100 transition-opacity duration-300" set:html={audit.icon} />
          </div>
          <h3 class="text-base font-semibold mb-3 group-hover:text-accent transition-colors duration-300">
            {audit.title}
          </h3>
          <p class="text-sm md:text-[0.9375rem] text-ink-secondary leading-relaxed">
            {audit.description}
          </p>
        </div>
      ))
    }
  </div>

  <!-- Mid-page CTA -->
  <div data-reveal style="--delay: 640ms" class="mt-16 text-center">
    <a
      href="#audit"
      class="inline-flex items-center gap-2 text-sm text-accent font-medium hover:text-accent-hover transition-colors duration-300"
    >
      Get your site checked
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>
</section>
