---
const steps = [
  {
    num: "01",
    title: "Free Audit",
    description: "Drop your URL. We scan your entire digital presence — speed, SEO, security, mobile, reviews, CTAs — and deliver a full diagnostic report within 48 hours.",
    accent: "accent",
  },
  {
    num: "02",
    title: "Gap Report",
    description: "We show you exactly what's broken, what it's costing you in real dollars, and rank every issue by impact. No jargon. Just numbers.",
    accent: "warning",
  },
  {
    num: "03",
    title: "Fix & Grow",
    description: "We rebuild what matters most — fast site, clear CTAs, proper SEO, review integration — and track the impact on your leads week by week.",
    accent: "success",
  },
];
---

<section
  class="section-over-hero bg-surface-alt py-20 md:py-32 px-6 md:px-12 lg:px-16 relative border-t border-rule"

>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-20">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
        Process
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl font-bold leading-[0.95] tracking-tight"
      >
        Three steps to<br class="hidden md:block" />
        <span class="text-accent">stop the bleeding.</span>
      </h2>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-0 md:gap-0">
    {
      steps.map((step, i) => (
        <div
          data-reveal
          style={`--delay: ${i * 120}ms`}
          class="relative border-t border-rule-light md:border-t-0 md:border-l md:first:border-l-0 md:border-rule-light"
        >
          <div class="p-8 md:p-10">
            <span class="text-6xl md:text-7xl font-bold tracking-tighter text-accent opacity-[0.12] block leading-none">{step.num}</span>
            <h3 class="text-2xl md:text-3xl font-bold mt-4 mb-4">{step.title}</h3>
            <p class="text-sm md:text-base text-ink-secondary leading-relaxed">
              {step.description}
            </p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Mid-page CTA -->
  <div data-reveal style="--delay: 360ms" class="mt-12 text-center">
    <a
      href="#audit"
      class="inline-flex items-center gap-3 px-7 py-3.5 rounded-sm bg-accent text-white text-sm font-semibold hover:bg-accent-hover transition-colors duration-300"
    >
      Get Your Free Audit
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </div>
</section>
