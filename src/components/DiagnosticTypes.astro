---
const segments = [
  {
    type: "blind-spender",
    label: "The Blind Spot",
    href: "#audit",
    pain: '"Why am I not getting calls?"',
    description:
      "No ads running, no tracking installed, no idea what's broken. Your website has issues you can't see — slow load times, missing CTAs, no SSL — and every one of them is silently turning away customers.",
    stat: "37/100",
    statLabel: "avg site score we find",
    color: {
      border: "border-accent/20",
      bg: "hover:bg-accent-muted",
      text: "text-accent",
      statBg: "bg-accent-subtle",
    },
    icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z",
  },
  {
    type: "pretty-and-broken",
    label: "The Leaky Funnel",
    href: "#audit",
    pain: '"Great website, great ads — no conversions"',
    description:
      "Your site looks professional and you're spending on marketing. But hidden issues — no after-hours capture, slow speed, no booking widget — are quietly killing your conversion rate.",
    stat: "68%",
    statLabel: "of leads lost to hidden gaps",
    color: {
      border: "border-accent/20",
      bg: "hover:bg-accent-muted",
      text: "text-accent",
      statBg: "bg-accent-subtle",
    },
    icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z",
  },
  {
    type: "half-built",
    label: "The Money Pit",
    href: "#audit",
    pain: '"Running ads but the website kills it"',
    description:
      "You're paying for Google Ads or Facebook traffic. But your site scores below average — visitors land, see a slow or broken experience, and bounce straight to your competitor.",
    stat: "$3K+",
    statLabel: "wasted per month on avg",
    color: {
      border: "border-accent/20",
      bg: "hover:bg-accent-muted",
      text: "text-accent",
      statBg: "bg-accent-subtle",
    },
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    type: "invisible",
    label: "The Hidden Gem",
    href: "#audit",
    pain: '"Good site, but nobody finds us"',
    description:
      "Your website actually scores above average. The problem? No SEO, no ads, no online presence strategy. You're invisible to the people searching for roofing services right now in your city.",
    stat: "0",
    statLabel: "organic visibility",
    color: {
      border: "border-accent/20",
      bg: "hover:bg-accent-muted",
      text: "text-accent",
      statBg: "bg-accent-subtle",
    },
    icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
  },
];
---

<section
  class="bg-surface py-20 md:py-32 px-6 md:px-12 lg:px-16 border-t border-rule"
>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-16 md:mb-24">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        Sound Familiar?
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl lg:text-[3.5rem] font-bold leading-[0.95] tracking-tight"
      >
        Every struggling Roofing business<br class="hidden md:block" />
        falls into <span class="text-accent">one of four traps.</span>
      </h2>
      <p data-reveal style="--delay: 200ms" class="mt-6 text-ink-secondary text-base md:text-lg leading-relaxed max-w-2xl">
        We've audited 1,200+ roofing company websites. The pattern is always one of these. Which one sounds like you?
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
    {segments.map((seg, i) => (
      <a
        href={seg.href}
        class={`group block rounded-sm border ${seg.color.border} ${seg.color.bg} p-6 md:p-8 transition-all duration-300`}
        data-reveal
        style={`--delay: ${i * 100}ms`}
      >
        <div class="flex items-start gap-4">
          <div class={`flex-none w-10 h-10 rounded-sm ${seg.color.statBg} flex items-center justify-center`}>
            <svg class={`w-5 h-5 ${seg.color.text}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={seg.icon} />
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class={`text-[10px] font-mono uppercase tracking-widest ${seg.color.text} mb-1.5`}>{seg.label}</p>
            <p class="text-lg md:text-xl font-bold leading-snug">{seg.pain}</p>
          </div>
        </div>

        <p class="mt-4 text-sm text-ink-secondary leading-relaxed">
          {seg.description}
        </p>

        <div class="mt-5 flex items-center justify-between">
          <div class={`inline-flex items-center gap-2 rounded-md ${seg.color.statBg} px-3 py-1.5`}>
            <span class={`text-sm font-bold font-mono ${seg.color.text}`}>{seg.stat}</span>
            <span class="text-[10px] text-ink-muted font-mono">{seg.statLabel}</span>
          </div>
          <span class="text-xs text-ink-muted group-hover:text-accent transition-colors duration-300 flex items-center gap-1">
            Learn more
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </div>
      </a>
    ))}
  </div>
</section>
