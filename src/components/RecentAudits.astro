---
import { reports } from "../data/reports";
import ReportCard from "./ReportCard.astro";

const audits = reports.slice(0, 3);
---

<section
  class="section-over-hero bg-surface py-20 md:py-32 px-6 md:px-12 lg:px-16 border-t border-rule"

  id="reports"
>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-16">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
        Recent Audits
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl font-bold leading-[0.95] tracking-tight"
      >
        Real reports.<br class="hidden md:block" />
        <span class="text-accent">Real problems found.</span>
      </h2>
      <p data-reveal style="--delay: 180ms" class="mt-4 text-ink-secondary text-sm md:text-base max-w-xl leading-relaxed">
        Every audit below is a real Roofing business. Click to see the full diagnostic report with issues, dollar impact, and recommended fixes.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {audits.map((audit, i) => (
      <div data-reveal style={`--delay: ${i * 100}ms`}>
        <ReportCard report={audit} />
      </div>
    ))}
  </div>

  <div class="mt-8 text-center">
    <a
      href="/reports/"
      data-reveal
      style="--delay: 300ms"
      class="inline-flex items-center gap-2 text-sm font-medium text-ink-secondary hover:text-accent transition-colors duration-300"
    >
      View all reports
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
