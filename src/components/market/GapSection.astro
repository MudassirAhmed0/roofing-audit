---
import { gapBlogLinks, type BlogLink } from "../../data/gap-blog-links";

interface Props {
  heading: string;
  frequency: number;
  count: number;
  total: number;
  severity: string;
  whyItMatters: string;
  whatTopSitesDo: string;
  costLine: string;
  problemSlug?: string;
  id?: string;
}

const {
  heading,
  frequency,
  count,
  total,
  severity,
  whyItMatters,
  whatTopSitesDo,
  costLine,
  problemSlug,
  id,
} = Astro.props;

const blogLinks: BlogLink[] = problemSlug ? (gapBlogLinks[problemSlug] || []) : [];

const pct = Math.round(frequency * 100);
const severityColors: Record<string, string> = {
  critical: "text-danger",
  high: "text-warning",
  medium: "text-ink-muted",
  low: "text-ink-faint",
};
const severityColor = severityColors[severity] || "text-ink-muted";
---

<section data-reveal class="py-10 border-t border-rule" id={id}>
  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-4">
    <h2 class="text-xl sm:text-2xl font-bold tracking-tight leading-tight">{heading}</h2>
    <span class={`text-xs font-mono uppercase tracking-wider ${severityColor}`}>{severity} severity</span>
  </div>

  <div class="flex items-baseline gap-1 mb-6">
    <span class="text-4xl sm:text-5xl font-bold text-accent">{pct}%</span>
    <span class="text-sm text-ink-muted">({count} of {total} sites)</span>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div>
      <h3 class="text-sm font-semibold text-ink mb-2">Why It Matters</h3>
      <p class="text-sm text-ink-secondary leading-relaxed">{whyItMatters}</p>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-ink mb-2">What Top-Scoring Sites Do</h3>
      <p class="text-sm text-ink-secondary leading-relaxed">{whatTopSitesDo}</p>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-ink mb-2">The Bottom Line</h3>
      <p class="text-sm text-ink-secondary leading-relaxed">{costLine}</p>
    </div>
  </div>

  <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
    {problemSlug && (
      <a href={`/market/roofing/${problemSlug}/`} class="text-sm text-accent hover:text-accent-hover transition-colors">
        Full report on this issue →
      </a>
    )}
    {blogLinks.length > 0 && blogLinks.map((link) => (
      <a href={`/blog/${link.slug}/`} class="text-xs text-ink-muted hover:text-accent transition-colors">
        {link.title} →
      </a>
    ))}
  </div>
</section>
