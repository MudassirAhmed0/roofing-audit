---
import ReportCard from "../ReportCard.astro";
import { reports, type Report } from "../../data/reports";

interface Props {
  /** Filter reports to a specific city */
  city?: string;
  /** Filter reports to a specific state */
  state?: string;
  /** Filter reports that contain a gap matching this substring */
  gapMatch?: string;
  /** Max reports to show */
  limit?: number;
  /** Section heading */
  heading?: string;
  /** Subheading text */
  subheading?: string;
}

const { city, state, gapMatch, limit = 9, heading, subheading } = Astro.props;

let filtered: Report[] = [...reports];

if (city && state) {
  filtered = filtered.filter((r) => r.city === city && r.state === state);
} else if (state) {
  filtered = filtered.filter((r) => r.state === state);
}

if (gapMatch) {
  const lower = gapMatch.toLowerCase();
  filtered = filtered.filter((r) =>
    r.gapSummary.some((g) => g.gap.toLowerCase().includes(lower))
  );
}

// Sort by score descending, take limit
filtered = filtered.sort((a, b) => (b.websiteQualityScore ?? b.totalScore) - (a.websiteQualityScore ?? a.totalScore)).slice(0, limit);

// Don't render if no matching reports
if (filtered.length === 0) return;

const defaultHeading = city
  ? `Roofing Audit Reports from ${city}`
  : state
    ? `Roofing Audit Reports from ${state}`
    : "Real Roofing Website Audit Reports";

const defaultSubheading = "See the exact issues found on real Roofing company websites.";
---

<section data-reveal class="py-8 border-t border-rule">
  <h2 class="text-lg font-bold tracking-tight mb-1">{heading || defaultHeading}</h2>
  <p class="text-xs text-ink-muted mb-4">{subheading || defaultSubheading}</p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    {filtered.map((report) => (
      <ReportCard report={report} compact />
    ))}
  </div>
  {filtered.length >= 3 && (
    <p class="mt-3">
      <a href="/reports/" class="text-xs text-accent hover:text-accent-hover transition-colors">
        View all audit reports →
      </a>
    </p>
  )}
</section>
