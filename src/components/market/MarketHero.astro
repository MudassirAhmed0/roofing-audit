---
interface Props {
  pretitle: string;
  title: string;
  subtitle: string;
  totalAudited: number;
  lastUpdated: string;
}

const { pretitle, title, subtitle, totalAudited, lastUpdated } = Astro.props;

const formattedDate = new Date(lastUpdated).toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});
---

<section class="pt-28 pb-12 sm:pt-32 sm:pb-16">
  <div class="px-6 md:px-12 lg:px-16">
    <p class="hero-reveal font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
      {pretitle}
    </p>
    <h1 class="hero-reveal text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1]" style="--delay:60ms">
      <Fragment set:html={title} />
    </h1>
    <p class="hero-reveal mt-4 text-ink-secondary text-lg leading-relaxed max-w-3xl" style="--delay:120ms">
      {subtitle}
    </p>
    <div class="hero-reveal mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-ink-faint font-mono" style="--delay:180ms">
      <span>Last updated: {formattedDate}</span>
      <span aria-hidden="true" class="hidden sm:inline">·</span>
      <span>{totalAudited.toLocaleString()} sites audited</span>
    </div>
  </div>
</section>
