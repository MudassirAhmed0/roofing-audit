---
interface StatItem {
  label: string;
  value: string;
  detail?: string;
}

interface Props {
  stats: StatItem[];
}

const { stats } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
  {stats.map((stat, i) => (
    <div
      data-reveal
      style={`--delay: ${i * 60}ms`}
      class="rounded-sm border border-rule bg-surface-alt/60 p-4"
    >
      <p class="text-2xl sm:text-3xl font-bold tracking-tight text-ink">{stat.value}</p>
      <p class="text-xs text-ink-muted mt-1 leading-snug">{stat.label}</p>
      {stat.detail && (
        <p class="text-[10px] text-ink-faint mt-0.5">{stat.detail}</p>
      )}
    </div>
  ))}
</div>
