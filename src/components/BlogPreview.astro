---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section class="py-20 sm:py-28 border-t border-rule">
  <div class="px-6 md:px-12 lg:px-16">
    <div class="flex items-end justify-between gap-4 mb-10">
      <div data-reveal>
        <p class="font-mono text-xs tracking-widest uppercase text-ink-muted mb-3">
          From the blog
        </p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight leading-[1.15]">
          What we're finding
        </h2>
      </div>
      <a
        href="/blog/"
        class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-ink-secondary hover:text-accent transition-colors duration-300"
        data-reveal style="--delay:80ms"
      >
        All posts
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id.replace(/\.md$/, "")}/`}
          class="group rounded-sm border border-rule overflow-hidden bg-surface-alt/40 transition-all duration-500 hover:border-accent/30 hover:shadow-[0_0_60px_rgba(14,165,233,0.06)]"
          data-reveal
          style={`--delay:${(i + 1) * 80}ms`}
        >
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={post.data.cover}
              alt={post.data.title}
              width="1080"
              height="1080"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="px-4 py-4 sm:px-5 sm:py-5">
            <h3 class="text-base font-semibold tracking-tight leading-snug group-hover:text-accent transition-colors duration-300 line-clamp-2">
              {post.data.title}
            </h3>
            <div class="mt-3 flex items-center gap-2 text-xs font-mono text-ink-faint">
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {post.data.date.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
              </time>
              <span class="text-rule">·</span>
              <span>{post.data.readTime}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <a
        href="/blog/"
        class="inline-flex items-center gap-2 text-sm font-medium text-ink-secondary hover:text-accent transition-colors"
        data-reveal
      >
        All posts
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
