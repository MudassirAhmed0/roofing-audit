---
const stats = [
  { value: 1200, suffix: "+", prefix: "", label: "Roofing Sites Audited" },
  { value: 11, suffix: "", prefix: "", label: "States Covered" },
  { value: 37, suffix: "/100", prefix: "", label: "Avg Site Score" },
  { value: 4.8, suffix: "", prefix: "", label: "Avg Google Rating" },
];
---

<section
  class="section-over-hero bg-surface py-16 md:py-28 px-6 md:px-12 lg:px-16 border-t border-rule"

>
  <div class="flex flex-col lg:flex-row gap-10 lg:gap-20">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase">
        Track Record
      </p>
    </div>
    <div class="lg:w-2/3">
      <div class="grid grid-cols-2 lg:grid-cols-4">
        {
          stats.map((stat, i) => (
            <div
              data-reveal
              style={`--delay: ${i * 100}ms`}
              class:list={[
                "py-6 lg:py-0",
                // Left border: on mobile, odd columns; on desktop, all except first
                i % 2 !== 0 ? "border-l border-rule-light pl-6 sm:pl-8" : "pr-2",
                i % 2 === 0 && i > 0 ? "lg:border-l lg:border-rule-light lg:pl-8" : "",
                // Top border on mobile for second row
                i >= 2 ? "border-t border-rule-light lg:border-t-0" : "",
              ]}
            >
              <span class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight block mb-2">
                {stat.value === 4.8 ? (
                  <span>4.8</span>
                ) : (
                  <span data-counter={stat.value} data-suffix={stat.suffix} data-prefix={stat.prefix}>
                    {stat.prefix}{stat.value}{stat.suffix}
                  </span>
                )}
              </span>
              <span class="text-[10px] text-ink-muted font-mono uppercase tracking-widest">{stat.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
