---
const problems = [
  {
    num: "01",
    stat: 74,
    suffix: "%",
    label: "No Online Booking",
    description: "3 out of 4 roofing websites have no way to book online. Customers expect to schedule a roofing the same way they order food — instantly. No booking widget means they'll find one who has it.",
    severity: "critical",
  },
  {
    num: "02",
    stat: 73,
    suffix: "%",
    label: "No Pricing Page",
    description: "73% of roofing sites hide their pricing. Homeowners comparison-shop. If they can't see a ballpark number on your site, they move on to the one that shows it.",
    severity: "critical",
  },
  {
    num: "03",
    stat: 65,
    suffix: "%",
    label: "No Contact Form",
    description: "65% of roofing websites have no contact form. If a customer can't reach you in 10 seconds, they're calling your competitor.",
    severity: "high",
  },
  {
    num: "04",
    stat: 62,
    suffix: "%",
    label: "Phone Not Clickable",
    description: "62% of sites have a phone number that isn't tap-to-call on mobile. Over 60% of your visitors are on their phones. Making them copy-paste your number loses half of them.",
    severity: "high",
  },
  {
    num: "05",
    stat: 51,
    suffix: "%",
    label: "No Reviews Displayed",
    description: "Roofing businesses average 4.8 stars on Google — but over half don't show reviews on their website. You're sitting on social proof and not using it.",
    severity: "medium",
  },
  {
    num: "06",
    stat: 46,
    suffix: "%",
    label: "No Trust Signals",
    description: "46% of roofing sites don't mention being bonded, insured, or background-checked. You're asking strangers to let you into their home — and not addressing their #1 concern.",
    severity: "medium",
  },
];

const severityColors: Record<string, string> = {
  critical: "bg-ink",
  high: "bg-ink-muted",
  medium: "bg-rule",
};
---

<section
  class="section-over-hero bg-surface-alt py-20 md:py-44 px-6 md:px-12 lg:px-16 relative border-t border-rule"
>
  <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 mb-16 md:mb-24">
    <div class="lg:w-1/3">
      <p data-reveal class="text-xs text-accent font-mono tracking-widest uppercase flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
        The Digital Bleeding
      </p>
    </div>
    <div class="lg:w-2/3">
      <h2
        data-reveal
        style="--delay: 100ms"
        class="text-3xl md:text-5xl lg:text-[3.5rem] font-bold leading-[0.95] tracking-tight"
      >
        We audited 1,200+ roofing websites.<br class="hidden md:block" />
        Here's what we <span class="text-accent">found.</span>
      </h2>
    </div>
  </div>

  <div class="space-y-0">
    {
      problems.map((problem, i) => (
        <div
          class="border-t border-rule py-8 md:py-10 group"
          data-reveal
          style={`--delay: ${i * 80}ms`}
        >
          <div class="flex flex-col md:flex-row md:items-start gap-6 md:gap-12">
            <div class="flex items-start gap-5 md:w-1/3 shrink-0">
              <!-- Severity bar -->
              <div class="flex flex-col items-center gap-3 pt-1">
                <span class="text-[10px] font-mono text-ink-muted">{problem.num}</span>
                <div class={`w-0.5 h-8 rounded-full ${severityColors[problem.severity]}`}></div>
              </div>
              <div>
                {problem.stat > 0 ? (
                  <span class="text-4xl md:text-5xl font-bold tracking-tight text-ink">
                    <span data-counter={problem.stat} data-suffix={problem.suffix}>0{problem.suffix}</span>
                  </span>
                ) : (
                  <span class="text-sm font-mono uppercase tracking-wider text-ink-muted">
                    Missing
                  </span>
                )}
                <span class="block text-sm font-medium text-ink mt-1">{problem.label}</span>
              </div>
            </div>
            <p class="text-ink-secondary text-base md:text-[1.0625rem] leading-relaxed md:w-2/3 max-w-xl">
              {problem.description}
            </p>
          </div>
        </div>
      ))
    }
    <div class="border-t border-rule" data-reveal-line style="--delay: 480ms"></div>
  </div>
</section>
