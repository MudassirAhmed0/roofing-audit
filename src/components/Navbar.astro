---
import marketData from "../data/market-data.json";

const topCities = marketData.cities
  .sort((a, b) => b.totalLeads - a.totalLeads)
  .slice(0, 8);

const topProblems = marketData.problems.slice(0, 6);
---

<header
  id="navbar"
  class="nav-dark fixed top-0 left-0 right-0 z-50 px-4 sm:px-6 md:px-12 lg:px-16 py-4"
>
  <nav class="flex items-center justify-between" aria-label="Main navigation">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Roofing Audit home">
      <svg width="28" height="28" viewBox="0 0 100 100" fill="none" class="shrink-0" aria-hidden="true">
        <path d="M40 12 L10 22V50Q10 85 40 95Q70 85 70 50V22L40 12Z" fill="#fff" stroke="#18181b" stroke-width="8" stroke-linejoin="round"/>
        <path d="M22 47L38 63L82 19" stroke="#fff" stroke-width="14" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M22 47L38 63L82 19" stroke="#059669" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M85 33Q85 45 97 45Q85 45 85 57Q85 45 73 45Q85 45 85 33Z" fill="#059669"/>
      </svg>
      <span class="text-sm font-semibold tracking-tight" style="color: var(--nav-text, #f1f5f9)">
        Roofing Audit
      </span>
    </a>

    <div class="flex items-center gap-4 sm:gap-6">
      <a
        href="/blog/"
        class="text-xs sm:text-sm font-medium tracking-tight hover:text-accent transition-colors duration-300"
        style="color: var(--nav-text, #f1f5f9)"
      >
        Blog
      </a>
      <a
        href="/reports/"
        class="text-xs sm:text-sm font-medium tracking-tight hover:text-accent transition-colors duration-300"
        style="color: var(--nav-text, #f1f5f9)"
      >
        Reports
      </a>

      <!-- Research dropdown (desktop only) -->
      <div class="nav-dropdown hidden md:block relative">
        <a
          href="/market/"
          class="nav-dropdown-trigger text-xs sm:text-sm font-medium tracking-tight hover:text-accent transition-colors duration-300 inline-flex items-center gap-1"
          style="color: var(--nav-text, #f1f5f9)"
        >
          Research
          <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="nav-dropdown-chevron transition-transform duration-200">
            <path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>

        <div class="nav-mega">
          <div class="grid grid-cols-3 gap-6">
            <!-- Column 1: Overview + States -->
            <div>
              <a href="/market/roofing/" class="block rounded-lg px-3 py-2.5 hover:bg-white/5 transition-colors mb-2">
                <p class="text-sm font-semibold text-ink">National Roofing Report</p>
                <p class="text-[11px] text-ink-muted mt-0.5">{marketData.national?.totalLeads ?? 0} sites analyzed across {marketData.national?.stateCount ?? 0} states</p>
              </a>
              <p class="text-[10px] font-mono font-semibold uppercase tracking-widest text-ink-faint px-3 mb-2 mt-3">By State</p>
              <ul class="space-y-0.5">
                {marketData.states.map((state) => (
                  <li>
                    <a href={`/market/roofing/${state.slug}/`} class="block rounded-lg px-3 py-1.5 text-sm text-ink-secondary hover:text-accent hover:bg-white/5 transition-colors">
                      {state.stateName}
                      <span class="text-ink-faint text-[10px] ml-1">{state.totalLeads}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Column 2: Top Cities -->
            <div>
              <p class="text-[10px] font-mono font-semibold uppercase tracking-widest text-ink-faint px-3 mb-2">Top Cities</p>
              <ul class="space-y-0.5">
                {topCities.map((city) => (
                  <li>
                    <a href={`/market/roofing/${city.slug}/`} class="block rounded-lg px-3 py-1.5 text-sm text-ink-secondary hover:text-accent hover:bg-white/5 transition-colors">
                      {city.city}, {city.state}
                      <span class="text-ink-faint text-[10px] ml-1">{city.totalLeads}</span>
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/market/" class="block px-3 mt-2 text-[11px] text-accent hover:text-accent-hover transition-colors">
                All {marketData.cities.length} cities →
              </a>
            </div>

            <!-- Column 3: Common Problems -->
            <div>
              <p class="text-[10px] font-mono font-semibold uppercase tracking-widest text-ink-faint px-3 mb-2">Common Problems</p>
              <ul class="space-y-0.5">
                {topProblems.map((problem) => (
                  <li>
                    <a href={`/market/roofing/${problem.slug}/`} class="block rounded-lg px-3 py-1.5 text-sm text-ink-secondary hover:text-accent hover:bg-white/5 transition-colors">
                      {problem.gap}
                      <span class="text-ink-faint text-[10px] ml-1">{Math.round(problem.nationalFrequency * 100)}%</span>
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/market/" class="block px-3 mt-2 text-[11px] text-accent hover:text-accent-hover transition-colors">
                All {marketData.problems.length} problems →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile: simple link -->
      <a
        href="/market/"
        class="md:hidden text-xs sm:text-sm font-medium tracking-tight hover:text-accent transition-colors duration-300"
        style="color: var(--nav-text, #f1f5f9)"
      >
        Research
      </a>

      <a
        href="/about/"
        class="hidden sm:inline text-xs sm:text-sm font-medium tracking-tight hover:text-accent transition-colors duration-300"
        style="color: var(--nav-text, #f1f5f9)"
      >
        About
      </a>
      <a
        href="/#audit"
        class="inline-flex items-center gap-2 px-3 py-2 sm:px-4 md:px-5 rounded-full bg-accent text-white text-[10px] sm:text-xs font-semibold tracking-wide uppercase hover:bg-accent-hover transition-colors duration-300 whitespace-nowrap shrink-0"
      >
        Free Audit
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="hidden sm:block">
          <path d="M2 6h8M7 3l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </nav>
</header>
