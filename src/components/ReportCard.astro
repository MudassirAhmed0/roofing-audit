---
import type { Report } from "../data/reports";

interface Props {
  report: Report;
  compact?: boolean;
}

const { report, compact = false } = Astro.props;

const score = report.websiteQualityScore ?? report.totalScore;
const circumference = 2 * Math.PI * 20;
const offset = circumference - (score / 100) * circumference;
const scoreColor =
  score >= 80 ? "#10b981" : score >= 60 ? "#f59e0b" : "#f87171";

const ringSize = compact ? "w-10 h-10" : "w-12 h-12";
const scoreTextSize = compact ? "text-[10px]" : "text-xs";
const cardPadding = compact ? "p-5" : "p-6";
const cardGap = compact ? "gap-3" : "gap-4";
const innerGap = compact ? "gap-3" : "gap-4";
---

<a
  href={`/report/${report.slug}/`}
  class={`group rounded-sm border border-rule bg-surface-card hover:border-accent/40 transition-colors duration-300 ${cardPadding} flex flex-col ${cardGap} h-full`}
>
  <div class={`flex items-center ${innerGap}`}>
    <div class={`relative ${ringSize} flex-none`}>
      <svg viewBox="0 0 48 48" class="w-full h-full -rotate-90">
        <circle cx="24" cy="24" r="20" fill="none" stroke="currentColor" stroke-width="3" class="text-rule" />
        <circle
          cx="24" cy="24" r="20"
          fill="none"
          stroke={scoreColor}
          stroke-width="3"
          stroke-linecap="round"
          stroke-dasharray={circumference}
          stroke-dashoffset={offset}
        />
      </svg>
      <div class="absolute inset-0 flex items-center justify-center">
        <span class={`${scoreTextSize} font-bold`} style={`color:${scoreColor}`}>{score}</span>
      </div>
    </div>
    <div class="min-w-0">
      <p class="font-semibold text-sm truncate group-hover:text-accent transition-colors">{report.name}</p>
      <p class="text-xs text-ink-muted font-mono truncate">{report.domain}</p>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <span class="text-xs font-mono text-ink-muted">
      {report.gapSummary.length} issues
    </span>
    <span class="w-px h-3 bg-rule flex-none"></span>
    <span class="text-xs font-mono text-ink-muted">
      {report.rating}&#9733; ({(report.reviewCount ?? 0).toLocaleString()})
    </span>
  </div>
  <p class="text-xs font-mono text-danger font-semibold">
    ~{report.impactEstimate.missedLeads} missed leads/mo
  </p>

  <div class="mt-auto pt-2 flex items-center gap-1.5 text-xs font-semibold text-ink-muted group-hover:text-accent transition-colors">
    View full report
    <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
</a>
