---
import {
  severityColors,
  severityOrder,
  categoryLabels,
  categoryIcons,
  type Report,
} from "../data/reports";

interface Props {
  report: Report;
}

const { report } = Astro.props;
const { businessSummary: biz, gapSummary: gaps, impactEstimate: impact } = report;

// Sort gaps by severity
const sortedGaps = [...gaps].sort(
  (a, b) => severityOrder[a.severity] - severityOrder[b.severity]
);

// Severity counts
const criticalCount = gaps.filter((g) => g.severity === "critical").length;
const highCount = gaps.filter((g) => g.severity === "high").length;
const mediumCount = gaps.filter((g) => g.severity === "medium").length;
const lowCount = gaps.filter((g) => g.severity === "low").length;

// Score ring
const scorePercent = report.websiteQualityScore ?? report.totalScore;
const circumference = 2 * Math.PI * 54;
const strokeDashoffset = circumference - (scorePercent / 100) * circumference;
const scoreColor =
  scorePercent >= 80 ? "#10b981" : scorePercent >= 60 ? "#f59e0b" : "#f87171";
---

<!-- Section 1: Hook -->
<section class="relative pt-28 pb-10 sm:pt-32 sm:pb-14">
  <div class="px-6 md:px-12 lg:px-16">
    <p class="font-mono text-xs tracking-widest uppercase text-ink-muted mb-4 hero-reveal">
      Website Audit &middot; {report.city}, {report.state}
    </p>
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-[1.1] hero-reveal" style="--delay:80ms">
      {report.name}
    </h1>
    <p class="mt-6 text-xl sm:text-2xl text-ink leading-relaxed font-medium hero-reveal" style="--delay:160ms">
      {biz.oneLiner}
    </p>
  </div>
</section>

<!-- Section 2: Your Website Score — curiosity hook -->
<section class="py-12 sm:py-16 border-t border-rule">
  <div class="px-6 md:px-12 lg:px-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
      Your Website Score
    </h2>
    <p class="mt-2 text-ink-secondary" data-reveal style="--delay:60ms">
      We scored your site across {new Set(gaps.map(g => g.category)).size} categories. Top-performing Roofing websites in competitive markets typically score between 80 and 90.
    </p>

    <div class="mt-8 grid grid-cols-1 sm:grid-cols-[auto_1fr] gap-8 lg:gap-12 items-start" data-reveal style="--delay:120ms">
      <!-- Score Ring -->
      <div class="flex flex-col items-center gap-2 flex-none">
        <div class="relative w-40 h-40 sm:w-48 sm:h-48">
          <svg viewBox="0 0 120 120" class="w-full h-full -rotate-90">
            <circle cx="60" cy="60" r="54" fill="none" stroke="currentColor" stroke-width="8" class="text-rule" />
            <circle cx="60" cy="60" r="54" fill="none" stroke={scoreColor} stroke-width="8" stroke-linecap="round" stroke-dasharray={circumference} stroke-dashoffset={strokeDashoffset} />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-5xl sm:text-6xl font-bold" style={`color:${scoreColor}`}>{scorePercent}</span>
            <span class="text-xs text-ink-muted font-mono">/100</span>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        <!-- Severity cards -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {criticalCount > 0 && (
            <div class="rounded-lg border border-red-500/20 bg-red-500/5 px-4 py-3 text-center">
              <p class="text-2xl font-bold text-red-400">{criticalCount}</p>
              <p class="text-xs font-mono text-ink-muted mt-0.5">Critical</p>
            </div>
          )}
          {highCount > 0 && (
            <div class="rounded-lg border border-orange-500/20 bg-orange-500/5 px-4 py-3 text-center">
              <p class="text-2xl font-bold text-orange-400">{highCount}</p>
              <p class="text-xs font-mono text-ink-muted mt-0.5">High</p>
            </div>
          )}
          {mediumCount > 0 && (
            <div class="rounded-lg border border-yellow-500/20 bg-yellow-500/5 px-4 py-3 text-center">
              <p class="text-2xl font-bold text-yellow-400">{mediumCount}</p>
              <p class="text-xs font-mono text-ink-muted mt-0.5">Medium</p>
            </div>
          )}
          {lowCount > 0 && (
            <div class="rounded-lg border border-blue-500/20 bg-blue-500/5 px-4 py-3 text-center">
              <p class="text-2xl font-bold text-blue-400">{lowCount}</p>
              <p class="text-xs font-mono text-ink-muted mt-0.5">Low</p>
            </div>
          )}
        </div>

        <!-- Stacked bar -->
        <div class="h-3 rounded-full bg-rule overflow-hidden flex w-full">
          {criticalCount > 0 && (
            <div class="bg-red-500 h-full" style={`width:${(criticalCount / gaps.length) * 100}%`}></div>
          )}
          {highCount > 0 && (
            <div class="bg-orange-500 h-full" style={`width:${(highCount / gaps.length) * 100}%`}></div>
          )}
          {mediumCount > 0 && (
            <div class="bg-yellow-500 h-full" style={`width:${(mediumCount / gaps.length) * 100}%`}></div>
          )}
          {lowCount > 0 && (
            <div class="bg-blue-500 h-full" style={`width:${(lowCount / gaps.length) * 100}%`}></div>
          )}
        </div>

        <p class="text-ink-secondary leading-relaxed">
          {biz.competitivePosition}
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: 3 Things Costing You Calls -->
<section class="py-12 sm:py-16 border-t border-rule">
  <div class="px-6 md:px-12 lg:px-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
      3 Things Costing You Calls Right Now
    </h2>

    <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-4">
      {biz.topThreeGaps.map((gap, i) => (
        <div
          class="flex items-start gap-4 rounded-xl border border-rule bg-surface-alt/40 px-5 py-5"
          data-reveal
          style={`--delay:${(i + 1) * 80}ms`}
        >
          <span class="flex-none w-10 h-10 rounded-lg bg-danger/15 text-danger flex items-center justify-center font-bold text-lg font-mono">
            {i + 1}
          </span>
          <p class="text-ink leading-relaxed">{gap}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Section 4: What this means -->
<section class="py-12 sm:py-16 border-t border-rule">
  <div class="px-6 md:px-12 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6" data-reveal>
      <!-- What we found -->
      <div class="rounded-xl border border-rule bg-surface-alt/40 p-5 sm:p-6">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex-none w-8 h-8 rounded-lg bg-danger/15 text-danger flex items-center justify-center">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </div>
          <p class="text-xs font-mono text-ink-muted uppercase tracking-wide">What we found</p>
        </div>
        <p class="text-ink leading-relaxed">{impact.bounceReason}</p>
      </div>

      <!-- What happens -->
      <div class="rounded-xl border border-rule bg-surface-alt/40 p-5 sm:p-6" data-reveal style="--delay:100ms">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex-none w-8 h-8 rounded-lg bg-warning/15 text-warning flex items-center justify-center">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <p class="text-xs font-mono text-ink-muted uppercase tracking-wide">What happens</p>
        </div>
        <p class="text-ink leading-relaxed">
          Visitors who can't quickly find what they need leave. For a site like yours, that could mean a significant number of potential customers each month never pick up the phone — they go to a competitor instead.
        </p>
      </div>

      <!-- What it could cost -->
      <div class="rounded-xl border border-rule bg-surface-alt/40 p-5 sm:p-6" data-reveal style="--delay:200ms">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex-none w-8 h-8 rounded-lg bg-accent/15 text-accent flex items-center justify-center">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="text-xs font-mono text-ink-muted uppercase tracking-wide">The opportunity</p>
        </div>
        <p class="text-ink leading-relaxed">
          Even converting <span class="font-semibold">2-5 more visitors into service calls</span> each month could mean <span class="font-bold text-accent">${impact.avgServiceCall * 2}-${impact.avgServiceCall * 5}+</span> in additional revenue — before counting system replacements.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Section 5: Seasonal Urgency -->
<section class="py-6 sm:py-7 bg-warning/8 border-t border-b border-warning/20">
  <div class="px-6 md:px-12 lg:px-16 flex items-start gap-3" data-reveal>
    <svg class="w-5 h-5 text-warning flex-none mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <p class="text-ink leading-relaxed">
      <span class="font-semibold text-warning">Timing matters:</span> {biz.seasonalUrgency}
    </p>
  </div>
</section>

<!-- Section 6: Where to Start -->
<section class="py-12 sm:py-16">
  <div class="px-6 md:px-12 lg:px-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
      Where to Start
    </h2>

    <div class="mt-8 rounded-xl border border-accent/30 bg-surface px-6 py-7" data-reveal style="--delay:80ms">
      <p class="text-lg text-ink leading-relaxed font-medium">{biz.recommendedFirstProject}</p>

      <div class="mt-5 flex items-center gap-2">
        <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm text-ink-secondary">These fixes can typically be done in <span class="font-semibold text-ink">{biz.recommendedFirstProjectTimeline}</span></span>
      </div>

      <div class="mt-5 pt-5 border-t border-rule">
        <p class="text-xs font-mono text-ink-muted uppercase tracking-wide mb-2">Longer term</p>
        <p class="text-sm text-ink-secondary leading-relaxed">{biz.growthOpportunity}</p>
      </div>
    </div>
  </div>
</section>

<!-- Section 7: Full Details (expandable) -->
<section class="py-12 sm:py-16 bg-surface-alt/30 border-t border-rule">
  <div class="px-6 md:px-12 lg:px-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
      Everything We Found
    </h2>
    <p class="mt-2 text-ink-secondary text-sm" data-reveal style="--delay:60ms">
      {gaps.length} issues across {new Set(gaps.map(g => g.category)).size} categories. Click any issue to see what it means for your business.
    </p>

    <div class="mt-8 space-y-3">
      {sortedGaps.map((gap, i) => {
        const colors = severityColors[gap.severity];
        const catLabel = categoryLabels[gap.category] || gap.category;
        return (
          <details
            class={`group rounded-xl border ${colors.border} ${colors.bg} overflow-hidden`}
            data-reveal
            style={`--delay:${Math.min(i * 40, 400)}ms`}
          >
            <summary class="px-4 py-3.5 sm:px-5 sm:py-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex items-start gap-2.5">
                <span class={`flex-none w-2.5 h-2.5 rounded-full mt-1.5 ${colors.dot}`}></span>
                <div class="flex-1 min-w-0">
                  <span class="font-medium text-sm sm:text-base leading-snug block">{gap.gap}</span>
                  <div class="mt-1.5 flex items-center gap-2">
                    <span class={`text-[10px] font-mono font-semibold ${colors.text} uppercase`}>
                      {gap.severity}
                    </span>
                    <span class="text-[10px] font-mono text-ink-muted hidden sm:inline">
                      {catLabel}
                    </span>
                    {gap.fixEffort === "quick-win" && (
                      <span class="text-[10px] font-mono text-success hidden sm:inline">
                        Quick Fix
                      </span>
                    )}
                  </div>
                </div>
                <svg class="w-4 h-4 text-ink-muted flex-none mt-1 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </summary>
            <div class="px-4 pb-4 pt-1 sm:px-5 sm:pb-5 border-t border-rule/50">
              <p class="text-sm text-ink-secondary leading-relaxed">{gap.impact}</p>
            </div>
          </details>
        );
      })}
    </div>
  </div>
</section>

<!-- Report view tracking -->
<script define:vars={{ slug: report.slug }}>
  if (!sessionStorage.getItem('rv_' + slug)) {
    sessionStorage.setItem('rv_' + slug, '1');
    fetch('https://social-posting-dashboard.vercel.app/api/outreach/track', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        slug: slug,
        referrer: document.referrer || null,
        ua: navigator.userAgent
      })
    }).catch(() => {});
  }
</script>

<!-- Section 8: CTA -->
<section class="py-14 sm:py-20 bg-accent/5 border-t border-accent/20">
  <div class="px-6 md:px-12 lg:px-16">
    <h2 class="text-2xl sm:text-3xl font-bold tracking-tight" data-reveal>
      Want to See What We'd Change?
    </h2>
    <p class="mt-4 text-ink-secondary leading-relaxed text-lg" data-reveal style="--delay:80ms">
      Most of the critical issues in this report can be fixed in a few days. If you'd like, we can walk you through exactly what we'd do and what to expect.
    </p>
    <p class="mt-4 text-ink leading-relaxed" data-reveal style="--delay:160ms">
      Reply to the email that brought you here, or reach out directly — no obligation, no pitch.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row items-start gap-4" data-reveal style="--delay:240ms">
      <a
        href="mailto:mudassir@creativeaxe.co?subject=Re: Website Audit — {report.name}"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-semibold text-sm hover:bg-accent-hover transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Send Us an Email
      </a>
    </div>
  </div>
</section>
